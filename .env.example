ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meuacervo?schema=public
POSTGRES_DB=meuacervo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=meuacervo;Username=postgres;Password=postgres
Jwt__Key=change-this-super-secret-key-in-production-with-at-least-32-characters
Jwt__Issuer=MeuAcervo
Jwt__Audience=MeuAcervo.Clients
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30
BookProviders__OpenLibrary__Enabled=true
BookProviders__OpenLibrary__BaseUrl=https://openlibrary.org
BookProviders__OpenLibrary__UserAgent=MeuAcervoAPI/1.0 (contato@example.com)
BookProviders__OpenLibrary__ContactEmail=contato@example.com
BookProviders__OpenLibrary__TimeoutSeconds=8
Database__ApplyMigrationsOnStartup=true
